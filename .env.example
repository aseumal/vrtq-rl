# OpenAI (for AutoGen LLM calls — optional)
OPENAI_API_KEY=your_key_here
# Model used by the opt-in agentic mode (agents/agentic_orchestrator.py)
AGENTIC_OPENAI_MODEL=gpt-4o-mini

# MLflow
MLFLOW_TRACKING_URI=./mlruns

# Model paths
MODEL_PATH=./models/ppo_vrtq_rl.zip
DQN_MODEL_PATH=./models/dqn_vrtq_rl.zip

# Dataset
RANDOM_SEED=42
N_TESTS=200
FAULT_RATE=0.15
TEST_BUDGET=50

# API
API_HOST=0.0.0.0
API_PORT=8000
